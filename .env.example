# Copie para .env e preencha. Opção 1: uma instância = uma empresa = um banco.
# Cada instância usa seu próprio .env (PORT, DB_NAME, PM2_APP_NAME diferentes).

# Porta do servidor HTTP (Ex.: 3007, 3008 para múltiplas instâncias)
PORT=3007

# URL pública HTTPS do painel (obrigatória para registrar webhook do Trello em produção)
# Ex.: https://seu-dominio.com:3007  ou  https://api.suaempresa.com
PUBLIC_APP_URL=http://vms.cutplay.com.br:3007

# Nome no PM2 (ex.: cs-canivete-suico, empresa-2). Usado pelo run-setup.js
PM2_APP_NAME=cs-canivete-suico

# Banco de dados (um database por empresa, ex.: pizzaria_loja1, pizzaria_loja2)
DB_HOST=vms.cutplay.com.br
DB_PORT=3306
DB_USER=mitouser
DB_PASSWORD=naoteconto
DB_NAME=pizzaria

# Multi-empresa: ID da empresa que ESTA instância do bot usa (mesmo banco, várias empresas)
EMPRESA_ID=1

# Sessão WhatsApp Web (obrigatório diferente em cada instância na mesma máquina)
# WHATSAPP_CLIENT_ID=bot-empresa-2

# JWT para autenticação do painel (use 16+ caracteres em produção)
JWT_SECRET=altere-este-segredo-jwt-em-producao

# Primeiro super administrador (criado uma vez pelo setup se ainda não existir)
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
